{
  "name": "free-llm-mcp-server",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server for free LLM APIs",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/server.js",
    "dev": "tsx src/server.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "smoke-test": "node --env-file=.env node_modules/.bin/tsx scripts/smoke-test.ts",
    "dashboard": "node --env-file=.env node_modules/.bin/tsx src/server.ts --sse"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cohere-ai": "^7.21.0",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "js-tiktoken": "^1.0.21",
    "lru-cache": "^11.0.0",
    "node-fetch": "^3.3.2",
    "quickjs-emscripten": "^0.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.2"
  }
}